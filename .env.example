# PostgreSQL connection string (local dev via pgAdmin4 / local Postgres on port 5432)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/sketchsync

# NextAuth (added in Phase 2)
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=http://localhost:3000

# Liveblocks (Phase 5) — get a secret key from https://liveblocks.io dashboard.
# Leave empty to run without real-time (local + DB only).
# LIVEBLOCKS_SECRET_KEY=sk_dev_xxxxxxxxxxxxxxxx
